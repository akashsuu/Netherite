{
"name": "netherite",
"version": "1.0.0",
"description": "Netherite is a powerful note-taking app with graph-based knowledge visualization.",
"author": "Akashsuu",
"main": "main.js",
"scripts": {
"start": "electron .",
"build": "electron-builder"
},
"devDependencies": {
"electron": "^30.0.0",
"electron-builder": "^26.8.1"
},
"build": {
"appId": "com.akashsuu.netherite",
"productName": "Netherite",
"directories": {
"output": "dist",
"buildResources": "build"
},
"files": [
"**/*",
"!dist/*"
],
"win": {
"target": "nsis",
"icon": "build/icon.ico"
},
"nsis": {
"oneClick": false,
"allowToChangeInstallationDirectory": true,
"installerIcon": "build/icon.ico",
"uninstallerIcon": "build/icon.ico",
"createDesktopShortcut": true,
"createStartMenuShortcut": true
}
}
}
